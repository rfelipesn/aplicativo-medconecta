{
  "version": 2,
  "projects": [
    {
      "name": "medconecta-web",
      "buildCommand": "npm run build -w @medconecta/shared && npm run build -w @medconecta/web",
      "outputDirectory": "apps/web/dist",
      "rootDirectory": "."
    }
  ],
  "builds": [
    {
      "src": "apps/web/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/web/dist/index.html"
    }
  ]
}
