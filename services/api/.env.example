NODE_ENV=development
API_PORT=3333
API_HOST=0.0.0.0

DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Transcrição de áudio (Whisper). Groq oferece whisper-large-v3 gratuito em
# https://console.groq.com  -> Settings -> API Keys.
OPENAI_API_KEY=
GROQ_API_KEY=
SENTRY_DSN=

# Expo Push (expo-server-sdk). Não exige chave de API para o endpoint público
# https://exp.host/--/api/v2/push/send — o token Expo já é o identificador.
