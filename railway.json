{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --include=dev --no-audit && npm run build:api",
    "watchPatterns": [
      "services/api/**",
      "packages/**",
      "package.json",
      "package-lock.json",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
