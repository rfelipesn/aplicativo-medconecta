{
  "name": "medconecta",
  "version": "0.1.0",
  "private": true,
  "description": "MEDconecta - aplicativo médico mobile (Expo) + painel web, BaaS-first (Supabase), offline-first (WatermelonDB).",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "npm run db:generate -w @medconecta/db",
    "db:studio": "npm run db:studio -w @medconecta/db"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.2"
}
