{
  "name": "medconecta",
  "version": "0.1.0",
  "private": true,
  "description": "MEDconecta - aplicativo médico mobile (Expo) + painel web, BaaS-first (Supabase), offline-first (WatermelonDB).",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "npm run dev -w @medconecta/api",
    "dev:web": "npm run dev -w @medconecta/web",
    "build": "turbo run build",
    "build:api": "npm run build -w @medconecta/shared && npm run build -w @medconecta/db && npm run build -w @medconecta/api",
    "start": "npm run start -w @medconecta/api",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "npm run db:generate -w @medconecta/db",
    "db:studio": "npm run db:studio -w @medconecta/db",
    "db:apply": "node packages/db/scripts/apply-migrations.mjs",
    "db:cleanup-e2e": "node packages/db/scripts/cleanup-e2e-users.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:dev": "docker compose --profile with-db up -d"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.18.2"
  }
}
