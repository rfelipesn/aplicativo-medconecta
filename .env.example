# ============================================================
# MEDconecta - variáveis de ambiente (exemplo)
# Copie para .env e preencha. NUNCA comite o .env real.
# Região de referência: sa-east-1 (São Paulo)
# ============================================================

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres (Prisma) - string de conexão direta do Supabase
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR_PROJECT.supabase.co:5432/postgres

# OpenAI (Fase 2: triagem gpt-4o-mini + transcrição Whisper) - opcional (Groq é o padrão)
OPENAI_API_KEY=sk-...

# Groq (padrão gratuito): Whisper (transcrição) + LLaMA 3.3 70B (triagem IA)
# Crie a chave em https://console.groq.com  -> Settings -> API Keys
GROQ_API_KEY=gsk_...

# Sentry (observabilidade, sem PHI)
SENTRY_DSN=

# API (Fastify)
API_PORT=3333
API_HOST=0.0.0.0

# Expo Push (expo-server-sdk). Não exige chave de API para o endpoint público
# https://exp.host/--/api/v2/push/send — o token Expo já é o identificador.
